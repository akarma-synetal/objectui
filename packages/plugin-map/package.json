{
  "name": "@object-ui/plugin-map",
  "version": "5.1.1",
  "type": "module",
  "license": "MIT",
  "description": "Map visualization plugin for Object UI",
  "homepage": "https://www.objectui.org/docs/plugins/plugin-map",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/objectstack-ai/objectui.git",
    "directory": "packages/plugin-map"
  },
  "bugs": {
    "url": "https://github.com/objectstack-ai/objectui/issues"
  },
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@object-ui/components": "workspace:*",
    "@object-ui/core": "workspace:*",
    "@object-ui/react": "workspace:*",
    "@object-ui/types": "workspace:*",
    "@objectstack/spec": "^4.0.5",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "react-map-gl": "^8.1.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.0"
  },
  "keywords": [
    "objectui",
    "sdui",
    "schema-driven-ui",
    "react",
    "tailwind",
    "shadcn",
    "objectstack",
    "plugin",
