{
  "type": "dashboard",
  "title": "Sales Overview (dataset + inline)",
  "columns": 2,
  "gap": 4,
  "dateRange": {
    "field": "created_at",
    "defaultRange": "this_quarter",
    "allowCustomRange": true
  },
  "globalFilters": [
    {
      "name": "region",
      "field": "region",
      "label": "Region",
      "type": "select",
      "options": ["EMEA", "APAC", "AMER"]
    }
  ],
  "widgets": [
    {
      "id": "revenue_total",
      "title": "Revenue",
      "type": "metric",
      "dataset": "sales",
      "values": ["revenue"]
    },
    {
      "id": "revenue_by_stage",
      "title": "Revenue by Stage",
      "type": "donut",
      "dataset": "sales",
      "dimensions": ["stage"],
      "values": ["revenue"]
    },
    {
      "id": "invoices_by_status",
      "title": "Invoices by Status",
      "type": "bar",
      "object": "invoices",
      "categoryField": "status",
      "aggregate": "count"
    }
  ]
}
